    as (

-- Transaction header fact table: one row per transaction/batch
-- Grain: Transaction ID
-- Purpose: Analyze transactions by customer, channel, payment method with aggregated metrics

WITH stg_transactions AS (
    SELECT * FROM NUAAV_DW.staging.stg_transactions
),

dim_client AS (
    SELECT * FROM NUAAV_DW.marts.dim_client
),

dim_customer AS (
    SELECT * FROM NUAAV_DW.marts.dim_customer
),

dim_date AS (
    SELECT * FROM NUAAV_DW.marts.dim_date
),

dim_payment_type AS (
    SELECT * FROM NUAAV_DW.marts.dim_payment_type
),

-- Aggregate to transaction level (header info only)
transaction_aggregates AS (
    SELECT
        transaction_id,
        order_id,
        client_id,
        customer_id,
        timestamp_str,
        payment_method,
        MAX(order_status) AS order_status,
        MAX(order_channel) AS order_channel,
        COUNT(DISTINCT order_id) AS order_count,
        COUNT(*) AS item_count,
        SUM(quantity) AS total_quantity,
        SUM(COALESCE(quantity * unit_price, 0)) AS total_line_amount,
        MAX(payment_amount) AS payment_amount,
        MAX(is_duplicate) AS is_duplicate_flag,
        MAX(has_negative_qty) AS has_negative_qty_flag,
        MAX(has_negative_amt) AS has_negative_amt_flag,
        MAX(has_missing_date) AS has_missing_date_flag,
        MAX(has_invalid_ref) AS has_invalid_ref_flag,
        MAX(has_missing_sku) AS has_missing_sku_flag,
        MAX(_source_file) AS source_file,
        MAX(_loaded_at) AS loaded_at
    FROM stg_transactions
    WHERE transaction_id IS NOT NULL
    GROUP BY transaction_id, order_id, client_id, customer_id, timestamp_str, payment_method
),

transactions_with_keys AS (
    SELECT
        ta.transaction_id,
        ta.order_id,
        dc.client_key,
        COALESCE(dcust.customer_key, NULL) AS customer_key,
        COALESCE(dd.date_key, NULL) AS date_key,
        COALESCE(dpt.payment_type_key, NULL) AS payment_type_key,
        ta.order_status,
        ta.order_channel,
        NULL::VARCHAR(50) AS payment_status,  -- To be populated from payments staging if available
        ta.order_count,
        ta.item_count,
        ta.total_quantity,
        ta.total_line_amount,
        ta.payment_amount,
        ta.is_duplicate_flag AS is_duplicate,
        ta.has_negative_qty_flag AS has_negative_qty,
        ta.has_negative_amt_flag AS has_negative_amt,
        ta.has_missing_date_flag AS has_missing_date,
        ta.has_invalid_ref_flag AS has_invalid_ref,
        ta.has_missing_sku_flag AS has_missing_sku,
        ta.source_file,
        ta.loaded_at
    FROM transaction_aggregates ta
    INNER JOIN dim_client dc ON ta.client_id = dc.client_id
    LEFT JOIN dim_customer dcust ON ta.customer_id = dcust.customer_id AND dc.client_key = dcust.client_key
    LEFT JOIN dim_date dd ON TRY_TO_DATE(ta.timestamp_str) = dd.full_date
    LEFT JOIN dim_payment_type dpt ON ta.payment_method = dpt.payment_method
)

SELECT * FROM transactions_with_keys
    )

