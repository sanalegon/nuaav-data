    as (

WITH stg_transactions AS (
    SELECT * FROM NUAAV_DW.staging.stg_transactions
),

dim_client AS (
    SELECT * FROM NUAAV_DW.marts.dim_client
),

dim_customer AS (
    SELECT * FROM NUAAV_DW.marts.dim_customer
),

dim_product AS (
    SELECT * FROM NUAAV_DW.marts.dim_product
),

dim_date AS (
    SELECT * FROM NUAAV_DW.marts.dim_date
),

dim_payment_type AS (
    SELECT * FROM NUAAV_DW.marts.dim_payment_type
),

transactions_with_keys AS (
    SELECT
        st.transaction_id,
        st.order_id,
        dc.client_key,
        COALESCE(dcust.customer_key, NULL) AS customer_key,
        COALESCE(dp.product_key, NULL) AS product_key,
        COALESCE(dd.date_key, NULL) AS date_key,
        COALESCE(dpt.payment_type_key, NULL) AS payment_type_key,
        st.quantity,
        st.unit_price,
        COALESCE(st.quantity * st.unit_price, 0) AS line_total,
        st.payment_amount,
        COALESCE(st.payment_method, 'Unknown') AS payment_method,
        NULL::VARCHAR(50) AS payment_status,  -- Will be populated from fact_orders join
        st.order_status,
        st.order_channel,
        st.is_duplicate,
        st.has_negative_qty,
        st.has_negative_amt,
        st.has_missing_date,
        st.has_invalid_ref,
        st.has_missing_sku,
        CONCAT_WS('; ',
            CASE WHEN st.is_duplicate THEN 'Duplicate transaction' ELSE NULL END,
            CASE WHEN st.has_negative_qty THEN 'Negative quantity' ELSE NULL END,
            CASE WHEN st.has_negative_amt THEN 'Negative amount' ELSE NULL END,
            CASE WHEN st.has_missing_date THEN 'Missing order date' ELSE NULL END,
            CASE WHEN st.has_invalid_ref THEN 'Invalid customer/SKU reference' ELSE NULL END,
            CASE WHEN st.has_missing_sku THEN 'Missing SKU' ELSE NULL END
        ) AS anomaly_notes,
        st.sku,
        st.customer_id,
        st.first_name,
        st.last_name,
        st.email,
        st.timestamp_str,
        st._source_file,
        st._loaded_at
    FROM stg_transactions st
    INNER JOIN dim_client dc ON st.client_id = dc.client_id
    LEFT JOIN dim_customer dcust ON st.customer_id = dcust.customer_id AND dc.client_key = dcust.client_key
    LEFT JOIN dim_product dp ON st.sku = dp.sku AND dc.client_key = dp.client_key
    LEFT JOIN dim_date dd ON TRY_TO_DATE(st.timestamp_str) = dd.full_date
    LEFT JOIN dim_payment_type dpt ON st.payment_method = dpt.payment_method
)

SELECT * FROM transactions_with_keys
    )

