),

stg_orders AS (
    SELECT * FROM NUAAV_DW.staging.stg_orders
),

order_items_with_keys AS (
    SELECT
        st.transaction_id,
        st.order_id,
        dc.client_key,
        COALESCE(dcust.customer_key, NULL) AS customer_key,
        COALESCE(dp.product_key, NULL) AS product_key,
