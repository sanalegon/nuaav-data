    as (

WITH stg_orders AS (
    SELECT * FROM NUAAV_DW.staging.stg_orders
),

stg_transactions AS (
    SELECT * FROM NUAAV_DW.staging.stg_transactions
),

dim_client AS (
    SELECT * FROM NUAAV_DW.marts.dim_client
),

dim_customer AS (
    SELECT * FROM NUAAV_DW.marts.dim_customer
),

dim_date AS (
    SELECT * FROM NUAAV_DW.marts.dim_date
),

dim_payment_type AS (
    SELECT * FROM NUAAV_DW.marts.dim_payment_type
),

-- Aggregate transactions to order level
order_aggregates AS (
    SELECT
        order_id,
        client_id,
        customer_id,
        timestamp_str,
        payment_method,
        MAX(order_status) AS order_status,
        MAX(order_channel) AS order_channel,
        COUNT(DISTINCT transaction_id) AS item_count,
        SUM(quantity) AS total_quantity,
        SUM(COALESCE(quantity * unit_price, 0)) AS total_amount,
        MAX(payment_amount) AS payment_amount,
        MAX(is_duplicate) AS is_duplicate_flag,
        MAX(has_negative_amt) AS has_negative_amt_flag,
        MAX(has_missing_date) AS has_missing_date_flag,
        MAX(has_invalid_ref) AS has_invalid_ref_flag,
        MAX(_source_file) AS source_file,
        MAX(_loaded_at) AS loaded_at
    FROM stg_transactions
    WHERE order_id IS NOT NULL
    GROUP BY order_id, client_id, customer_id, timestamp_str, payment_method
),

orders_with_keys AS (
    SELECT
        oa.order_id,
        dc.client_key,
        COALESCE(dcust.customer_key, NULL) AS customer_key,
        COALESCE(dd.date_key, NULL) AS date_key,
        COALESCE(dpt.payment_type_key, NULL) AS payment_type_key,
        oa.order_status,
        oa.order_channel,
        NULL::VARCHAR(50) AS payment_status,  -- To be populated from payments staging if available
        oa.total_amount,
        oa.item_count,
        oa.payment_amount,
        oa.is_duplicate_flag AS is_duplicate,
        oa.has_negative_amt_flag AS has_negative_amt,
        oa.has_missing_date_flag AS has_missing_date,
        oa.has_invalid_ref_flag AS has_invalid_ref,
        oa.source_file,
        oa.loaded_at
    FROM order_aggregates oa
    INNER JOIN dim_client dc ON oa.client_id = dc.client_id
    LEFT JOIN dim_customer dcust ON oa.customer_id = dcust.customer_id AND dc.client_key = dcust.client_key
    LEFT JOIN dim_date dd ON TRY_TO_DATE(oa.timestamp_str) = dd.full_date
    LEFT JOIN dim_payment_type dpt ON oa.payment_method = dpt.payment_method
)

SELECT * FROM orders_with_keys
    )

