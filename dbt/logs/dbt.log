        COALESCE(dp.product_key, NULL) AS product_key,
        COALESCE(dd.date_key, NULL) AS date_key,
        COALESCE(dpt.payment_type_key, NULL) AS payment_type_key,
        st.quantity,
        st.unit_price,
        COALESCE(st.quantity * st.unit_price, 0) AS line_total,
        st.payment_amount,
        COALESCE(st.payment_method, 'Unknown') AS payment_method,
