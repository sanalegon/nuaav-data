        'UNKNOWN' AS loyalty_tier,
        'UNMATCHED' AS signup_source,
        FALSE AS is_active,
        FALSE AS is_email_valid,
        CURRENT_TIMESTAMP() AS loaded_at
),

final_customers AS (
