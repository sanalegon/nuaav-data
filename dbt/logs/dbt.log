                END
            WHEN sc.client_id = 'C' THEN
                CASE sc.loyalty_tier
                    WHEN 'VIP' THEN 'PLATINUM'
                    WHEN 'REGULAR' THEN 'SILVER'
                    WHEN 'NEW' THEN 'BRONZE'
                    ELSE 'UNKNOWN'
                END
            ELSE 'UNKNOWN'
        END AS loyalty_tier,
        sc.signup_source,
        sc.is_active,
        CASE 
