  as (
    -- =============================================================================
-- MODEL      : stg_transactions
-- PURPOSE    : Unified Transactions staging for all clients (A, C, and future).
--              • Client A: Parse XML transactions (XMLGET); flatten Items array
--              • Client C: Parse JSON transactions (JSON accessor); flatten items array
--              • Both: Flatten items array to line-item rows
--              • Union both clients with client_id tag
--              • Apply anomaly flags (6 types)
--              • Deduplicate per client per transaction_id
--
-- STRUCTURE NOTES:
--   Client A (XML):
--     - Root: <SalesData client="ClientA" generatedAt="...">
--     - Each: <Transaction> with <TransactionID>, <Order>, <Items>, <Payment>
--     - Customer, Order, Payment are SINGULAR (not arrays)
--     - Only Items contains multiple <Item> elements
--     - Timestamp: batch-level (generatedAt), not per transaction
--   Client C (JSON):
--     - Root: {client, batchTimestamp, transactions: [...]}
--     - Each transaction: {id, order{id, date, customer{id, name, email}}, items[], payment}
--     - Customer is nested in Order (not separate)
--     - Price is nested object {amount, currency}
--     - No per-transaction timestamp
-- =============================================================================

-- ============================================================================
-- CLIENT A: XML PARSING
-- ============================================================================
WITH client_a_raw_xml AS (
    SELECT
        _source_file,
        _raw_xml,
        _loaded_at
    FROM NUAAV_DW.RAW.CLIENT_A_TRANSACTIONS_XML
),

client_a_parsed_envelope AS (
    SELECT
        _source_file,
        XMLGET(_raw_xml, 'SalesData')::OBJECT AS sales_data_obj,
        _loaded_at
    FROM client_a_raw_xml
),

client_a_extracted_txns AS (
    SELECT
        VALUE::OBJECT AS txn_obj,
        'A' AS client_id,
        _source_file,
        _loaded_at
    FROM client_a_parsed_envelope,
    LATERAL FLATTEN(INPUT => sales_data_obj, MODE => 'RECURSE', RECURSIVE_DEPTH => 2)
    WHERE KEY = 'Transaction'
),

client_a_parsed_txns AS (
    SELECT
        XMLGET(txn_obj, 'TransactionID')::STRING AS transaction_id,
        XMLGET(XMLGET(txn_obj, 'Order'), 'OrderID')::STRING AS order_id,
        XMLGET(XMLGET(txn_obj, 'Order'), 'OrderDate')::STRING AS order_date,
        XMLGET(XMLGET(XMLGET(txn_obj, 'Order'), 'Customer'), 'CustomerID')::STRING AS customer_id,
        -- Handle both <LastName> and <LastLastName> anomaly
        COALESCE(
            XMLGET(XMLGET(XMLGET(txn_obj, 'Order'), 'Customer'), 'LastName')::STRING,
            XMLGET(XMLGET(XMLGET(txn_obj, 'Order'), 'Customer'), 'LastLastName')::STRING
        ) AS last_name,
        XMLGET(XMLGET(XMLGET(txn_obj, 'Order'), 'Customer'), 'FirstName')::STRING AS first_name,
        XMLGET(XMLGET(XMLGET(txn_obj, 'Order'), 'Customer'), 'Email')::STRING AS email,
        XMLGET(XMLGET(txn_obj, 'Payment'), 'Method')::STRING AS payment_method,
        TRY_TO_NUMBER(XMLGET(XMLGET(txn_obj, 'Payment'), 'Amount')::STRING, 14, 2) AS payment_amount,
        XMLGET(txn_obj, 'Items')::OBJECT AS items_container,
        client_id,
        ROW_NUMBER() OVER (PARTITION BY XMLGET(txn_obj, 'TransactionID') ORDER BY _loaded_at) AS txn_rn,
        _source_file,
        _loaded_at
    FROM client_a_extracted_txns
),

client_a_flattened_items AS (
    SELECT
        transaction_id,
        customer_id,
        first_name,
        last_name,
        email,
        order_id,
        order_date,
        payment_method,
        payment_amount,
        XMLGET(item_obj, 'SKU')::STRING AS sku,
        XMLGET(item_obj, 'Description')::STRING AS description,
        TRY_TO_NUMBER(XMLGET(item_obj, 'Quantity')::STRING) AS quantity,
        TRY_TO_NUMBER(XMLGET(item_obj, 'UnitPrice')::STRING, 12, 2) AS unit_price,
        client_id,
        txn_rn,
        ROW_NUMBER() OVER (PARTITION BY transaction_id, item_obj ORDER BY _loaded_at) AS item_rn,
        _source_file,
        _loaded_at
    FROM client_a_parsed_txns,
    LATERAL FLATTEN(INPUT => XMLGET(items_container, 'Item'), MODE => 'ARRAY') items(item_obj)
),

client_a_with_flags AS (
    SELECT
        transaction_id,
        customer_id,
        email,
        first_name,
        last_name,
        order_id,
        NULL::STRING AS order_channel,  -- Not available in XML
        NULL::STRING AS order_status,   -- Not available in XML
        payment_method,
        payment_amount,
        NULL::STRING AS item_id,        -- Not available in XML; use SKU if needed
        sku,
        quantity,
        unit_price,
        NULL::NUMBER AS line_total,     -- Not available in XML; calculate in marts if needed
        NULL::STRING AS timestamp_str,  -- Batch-level only, no per-transaction timestamp
        CASE WHEN txn_rn > 1 THEN TRUE ELSE FALSE END AS is_duplicate,
        CASE WHEN quantity IS NULL OR quantity < 0 THEN TRUE ELSE FALSE END AS has_negative_qty,
        CASE WHEN payment_amount IS NULL OR payment_amount < 0 THEN TRUE ELSE FALSE END AS has_negative_amt,
        FALSE AS has_missing_date,      -- No per-transaction timestamp; batch-level only
        CASE WHEN order_id IS NULL OR order_id = '' THEN TRUE ELSE FALSE END AS has_invalid_ref,
        CASE WHEN sku IS NULL OR sku = '' THEN TRUE ELSE FALSE END AS has_missing_sku,
        client_id,
        _source_file,
        _loaded_at
    FROM client_a_flattened_items
    WHERE item_rn = 1
),

-- ============================================================================
-- CLIENT C: JSON PARSING
-- ============================================================================
client_c_raw_json AS (
    SELECT
        _source_file,
        _raw_json,
        _loaded_at
    FROM NUAAV_DW.RAW.CLIENT_C_TRANSACTIONS_JSON
),

client_c_parsed_json AS (
    SELECT
        _raw_json:transaction_id::STRING AS transaction_id,
        _raw_json:timestamp::STRING AS timestamp_str,
        _raw_json:customer::OBJECT AS customer_obj,
        _raw_json:order::OBJECT AS order_obj,
        _raw_json:payment::OBJECT AS payment_obj,
        _raw_json:items AS items_array,
        'C' AS client_id,
        _source_file,
        _loaded_at,
        ROW_NUMBER() OVER (PARTITION BY _raw_json:transaction_id ORDER BY _loaded_at) AS txn_rn
    FROM client_c_raw_json
),

client_c_filtered_txns AS (
    SELECT *
    FROM client_c_parsed_json
    WHERE ARRAY_SIZE(items_array) > 0 OR txn_rn = 1
),

client_c_flattened_items AS (
    SELECT
        transaction_id,
        customer_obj:customer_id::STRING AS customer_id,
        customer_obj:email::STRING AS email,
        customer_obj:first_name::STRING AS first_name,
        customer_obj:last_name::STRING AS last_name,
        order_obj:order_id::STRING AS order_id,
        order_obj:order_channel::STRING AS order_channel,
        order_obj:order_status::STRING AS order_status,
        payment_obj:payment_method::STRING AS payment_method,
        TRY_TO_NUMBER(payment_obj:amount::STRING, 14, 2) AS payment_amount,
        item_variant:item_id::STRING AS item_id,
        item_variant:sku::STRING AS sku,
        TRY_TO_NUMBER(item_variant:quantity::STRING) AS quantity,
        TRY_TO_NUMBER(item_variant:unit_price::STRING, 12, 2) AS unit_price,
        TRY_TO_NUMBER(item_variant:line_total::STRING, 14, 2) AS line_total,
        timestamp_str,
        client_id,
        ROW_NUMBER() OVER (PARTITION BY transaction_id ORDER BY _loaded_at) AS txn_rn,
        ROW_NUMBER() OVER (PARTITION BY transaction_id, item_variant ORDER BY _loaded_at) AS item_rn,
        _source_file,
        _loaded_at
    FROM client_c_filtered_txns,
    LATERAL FLATTEN(INPUT => items_array, MODE => 'ARRAY') items(item_variant)
),

client_c_with_flags AS (
    SELECT
        transaction_id,
        customer_id,
        email,
        first_name,
        last_name,
        order_id,
        order_channel,
        order_status,
        payment_method,
        payment_amount,
        item_id,
        sku,
        quantity,
        unit_price,
        line_total,
        timestamp_str,
        CASE WHEN txn_rn > 1 THEN TRUE ELSE FALSE END AS is_duplicate,
        CASE WHEN quantity IS NULL OR quantity < 0 THEN TRUE ELSE FALSE END AS has_negative_qty,
        CASE WHEN payment_amount IS NULL OR payment_amount < 0 THEN TRUE ELSE FALSE END AS has_negative_amt,
        CASE WHEN TRY_TO_DATE(timestamp_str, 'YYYY-MM-DD HH24:MI:SS') IS NULL THEN TRUE ELSE FALSE END AS has_missing_date,
        CASE WHEN order_id IS NULL OR order_id = '' THEN TRUE ELSE FALSE END AS has_invalid_ref,
        CASE WHEN sku IS NULL OR sku = '' THEN TRUE ELSE FALSE END AS has_missing_sku,
        client_id,
        _source_file,
        _loaded_at
    FROM client_c_flattened_items
    WHERE item_rn = 1
),

-- ============================================================================
-- UNION AND FINAL DEDUP
-- ============================================================================
union_clients AS (
    SELECT * FROM client_a_with_flags
    UNION ALL
    SELECT * FROM client_c_with_flags
),

final_dedup AS (
    SELECT
        transaction_id,
        customer_id,
        email,
        first_name,
        last_name,
        order_id,
        order_channel,
        order_status,
        payment_method,
        payment_amount,
        item_id,
        sku,
        quantity,
        unit_price,
        line_total,
        timestamp_str,
        is_duplicate,
        has_negative_qty,
        has_negative_amt,
        has_missing_date,
        has_invalid_ref,
        has_missing_sku,
        client_id,
        _source_file,
        _loaded_at
    FROM union_clients
    WHERE is_duplicate = FALSE
)

SELECT * FROM final_dedup
ORDER BY client_id, transaction_id, item_id
  )
